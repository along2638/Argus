# MinIO
MINIO_ENDPOINT=your_minio_endpoint:9000
MINIO_BUCKET=your_bucket_name
MINIO_ACCESS_KEY=your_access_key
MINIO_SECRET_KEY=your_secret_key

# MySQL
MYSQL_DSN=mysql+aiomysql://username:password@host:port/database_name
# 注意密码中 # 需 URL 编码为 %23，$ 需编码为 %24

# Redis
REDIS_URL=redis://:password@host:port/db_number

# 模型路径（ONNX 格式）
# 通用模型（人）
YOLO_ONNX_PATH=./models/onnx/yolo11l.onnx
# 火灾/烟雾检测模型
FIRE_SMOKE_MODEL_PATH=./models/onnx/fire_smoke_v2.onnx
# 安全帽检测模型
HELMET_MODEL_PATH=./models/onnx/helmet_fp16.onnx

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000
MAX_CONCURRENT_STREAMS=10
CONFIDENCE_THRESHOLD=0.3

# 告警冷却时间(秒)
ALARM_COOLDOWN_TTL=30

# ARQ Worker 配置
ARQ_MAX_JOBS=20
ARQ_QUEUE_WARNING_THRESHOLD=100
